# Copy this to .env.render locally if you want to use Render's API/CLI.
# Never commit the filled file.
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RENDER_OWNER_ID=usr_or_team_workspace_id_from_render_settings
RENDER_REPO=https://github.com/SibOP1/Agen

# Render service name used by render.yaml.
RENDER_SERVICE_NAME=agen-multiplayer

# Public WebSocket endpoint after Render creates the service.
VITE_WS_URL=wss://agen-multiplayer.onrender.com
